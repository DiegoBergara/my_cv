---
import type { Locale } from '@/config/site';
import { content, skills } from '@/config/site';
import SkillsCarousel from './SkillsCarousel';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = content[locale].skills;
const categoryKeys = ['backend', 'frontend', 'devops'] as const;
---

<section id="skills" class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <h2 class="reveal mb-12 text-3xl font-bold md:text-4xl">{t.title}</h2>

    <div class="space-y-10">
      {categoryKeys.map((key, idx) => (
        <div class={`reveal reveal-d${idx + 1}`}>
          <h3 class="mb-4 text-sm font-medium uppercase tracking-wider text-white/40">
            {t.categories[key]}
          </h3>
          <SkillsCarousel
            client:visible
            items={skills[key]}
            direction={idx % 2 === 0 ? 'left' : 'right'}
            speed={25 + idx * 5}
          />
        </div>
      ))}
    </div>
  </div>
</section>
