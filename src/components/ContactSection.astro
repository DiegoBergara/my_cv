---
import type { Locale } from '@/config/site';
import { content, siteConfig } from '@/config/site';
import { Button } from './ui/button';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = content[locale].contact;
---

<section id="contact" class="py-24 md:py-32">
  <div class="mx-auto max-w-3xl px-4 text-center md:px-6">
    <h2 class="reveal mb-6 text-3xl font-bold md:text-4xl">{t.title}</h2>
    <p class="reveal reveal-d1 mb-10 text-lg text-white/60">{t.subtitle}</p>

    <div class="reveal reveal-d2 mb-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <Button asChild size="lg">
        <a href={t.primaryCta.href} target="_blank" rel="noopener noreferrer">
          {t.primaryCta.label}
        </a>
      </Button>
      <Button asChild variant="outline" size="lg">
        <a href={t.secondaryCta.href}>
          {t.secondaryCta.label}
        </a>
      </Button>
    </div>

    <div class="reveal reveal-d3 flex items-center justify-center gap-6">
      <a
        href={siteConfig.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg p-2 text-white/40 transition-colors hover:text-primary"
        aria-label="LinkedIn"
      >
        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a
        href={siteConfig.social.credly}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg p-2 text-white/40 transition-colors hover:text-primary"
        aria-label="Credly"
      >
        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm-.857 17.571c-3.078 0-5.571-2.493-5.571-5.571s2.493-5.571 5.571-5.571c1.714 0 3.257.786 4.286 2.014l-2.143 1.629A2.78 2.78 0 0 0 11.143 9.2c-1.543 0-2.8 1.257-2.8 2.8s1.257 2.8 2.8 2.8a2.78 2.78 0 0 0 2.143-.871l2.143 1.628a5.544 5.544 0 0 1-4.286 2.014zm6.428-3.857h-1.714v1.715h-1.143v-1.715h-1.714v-1.143h1.714v-1.714h1.143v1.714h1.714v1.143z"/>
        </svg>
      </a>
      <a
        href={`mailto:${siteConfig.email}`}
        class="rounded-lg p-2 text-white/40 transition-colors hover:text-primary"
        aria-label="Email"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
        </svg>
      </a>
    </div>
  </div>
</section>
