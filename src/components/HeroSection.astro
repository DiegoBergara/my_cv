---
import type { Locale } from '@/config/site';
import { content } from '@/config/site';
import HeroBackground from './HeroBackground';
import AnimatedText from './AnimatedText';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = content[locale].hero;
---

<section id="hero" class="relative flex min-h-screen items-center justify-center overflow-hidden">
  <HeroBackground client:load className="absolute inset-0" />

  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-base" />

  <div class="relative z-10 mx-auto max-w-4xl px-4 pt-20 text-center">
    <span
      class="mb-6 inline-block rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5 text-sm font-medium text-primary"
    >
      {t.badge}
    </span>

    <AnimatedText
      client:load
      text={t.title}
      as="h1"
      className="mb-6 justify-center text-4xl font-bold leading-tight tracking-tight md:text-5xl lg:text-6xl"
      delay={30}
    />

    <p class="reveal mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-white/70 md:text-xl">
      {t.subtitle}
    </p>

    <div class="reveal reveal-d2 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href={t.primaryCta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline-cta"
      >
        {t.primaryCta.label}
      </a>
      <a href={t.secondaryCta.href} class="btn-outline-cta">
        {t.secondaryCta.label}
      </a>
    </div>
  </div>
</section>
