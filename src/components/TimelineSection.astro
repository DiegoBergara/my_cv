---
import type { Locale } from '@/config/site';
import { content } from '@/config/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = content[locale].experience;
---

<section id="experience" class="py-24 md:py-32">
  <div class="mx-auto max-w-4xl px-4 md:px-6">
    <h2 class="reveal mb-16 text-3xl font-bold md:text-4xl">{t.title}</h2>

    <div class="relative">
      <div
        class="absolute left-[7px] top-2 bottom-2 w-px bg-gradient-to-b from-primary/50 via-secondary/30 to-transparent md:left-1/2 md:-translate-x-px"
        aria-hidden="true"
      />

      {t.items.map((item, idx) => {
        const isEven = idx % 2 === 0;
        return (
          <div
            class={`reveal reveal-d${Math.min(idx + 1, 4)} relative mb-12 pl-10 last:mb-0 md:pl-0 ${isEven ? 'md:pr-[52%] md:text-right' : 'md:pl-[52%]'}`}
          >
            <div
              class={`absolute left-0 top-1.5 h-3.5 w-3.5 rounded-full border-2 border-primary bg-base md:left-1/2 md:-translate-x-1/2`}
              aria-hidden="true"
            />
            <div class={isEven ? 'md:mr-6' : 'md:ml-6'}>
              <span class="mb-1 block text-sm font-medium text-primary">{item.period}</span>
              <h3 class="mb-2 text-lg font-semibold">{item.title}</h3>
              <p class="leading-relaxed text-white/60">{item.description}</p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
