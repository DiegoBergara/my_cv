---
import { siteConfig, supportedLocales, type Locale, content } from '@/config/site';
import '@/styles/global.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = content[locale];
const canonicalPath = locale === 'es' ? '/' : `/${locale}/`;
const canonicalUrl = new URL(canonicalPath, siteConfig.site).toString();
---

<!doctype html>
<html lang={locale} class="font-sans">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{t.seo.title}</title>
    <meta name="description" content={t.seo.description} />
    <meta name="author" content={siteConfig.author} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={t.seo.title} />
    <meta property="og:description" content={t.seo.description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(siteConfig.ogImage, siteConfig.site).toString()} />
    <meta property="og:locale" content={locale === 'es' ? 'es_UY' : 'en_US'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t.seo.title} />
    <meta name="twitter:description" content={t.seo.description} />
    <meta name="theme-color" content="#0a0a0f" />

    {supportedLocales.map((loc) => (
      <link
        rel="alternate"
        hreflang={loc}
        href={new URL(loc === 'es' ? '/' : `/${loc}/`, siteConfig.site).toString()}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={siteConfig.site} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: siteConfig.author,
        url: siteConfig.site,
        sameAs: [siteConfig.social.linkedin, siteConfig.social.credly],
        email: siteConfig.email,
        jobTitle: 'Senior Full Stack Developer',
      })}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen">
    <a
      href="#main-content"
      class="fixed left-2 top-2 z-[100] -translate-y-20 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-base transition-transform focus:translate-y-0"
    >
      {locale === 'es' ? 'Saltar al contenido' : 'Skip to content'}
    </a>
    <slot />
    <script>
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
    </script>
  </body>
</html>
